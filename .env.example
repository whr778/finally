# Required: OpenRouter API key for LLM chat functionality.
# If absent or empty (and LLM_MOCK is not "true"), chat endpoints return a
# descriptive error; market data, trading, and watchlist still work normally.
OPENROUTER_API_KEY=

# Optional: Massive (Polygon.io) API key for real market data.
# If set and non-empty, the backend uses Massive's REST API.
# If absent or empty, the built-in market simulator is used (default).
MASSIVE_API_KEY=

# Optional: when "true", the backend returns deterministic mock LLM responses
# instead of calling OpenRouter. Useful for E2E tests and offline development.
LLM_MOCK=false
